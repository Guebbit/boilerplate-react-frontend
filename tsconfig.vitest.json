{
    "extends": "./tsconfig.app.json",
    "include": [
        "api",
        "src/**/*",
        "tests/**/*.test.ts",
        "tests/**/*.test.tsx"
    ],
    "exclude": ["tests/unit/**/*"],
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
        "types": ["vite/client", "node", "jsdom", "vitest/globals"]
    }
}
